{
  "name": "pink-fm",
  "private": true,
  "version": "1.0.0",
  "description": "A profile-driven, local-first retro mood radio gift PWA.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "content:validate": "tsx scripts/validate-content.ts",
    "gift:create": "tsx scripts/create-gift.ts",
    "catalog:source:apple": "tsx scripts/catalog-source-apple.ts",
    "catalog:prepare:siti": "tsx scripts/prepare-siti-catalog.ts",
    "catalog:import": "tsx scripts/catalog-import.ts",
    "catalog:audit": "tsx scripts/catalog-audit.ts",
    "catalog:coverage": "tsx scripts/catalog-coverage.ts",
    "catalog:dedupe": "tsx scripts/catalog-dedupe.ts",
    "bot:embeddings": "tsx scripts/precompute-embeddings.ts",
    "bot:evaluation:generate": "tsx scripts/generate-bot-evaluation.ts",
    "bot:evaluate": "tsx scripts/evaluate-bot.ts",
    "icons:generate": "node scripts/generate-icons.mjs",
    "qa:browser": "node scripts/browser-qa.mjs",
    "verify": "npm run lint && npm run typecheck && npm run content:validate && npm run catalog:audit -- --slug siti && npm run test && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/manrope": "^5.2.8",
    "@huggingface/transformers": "^4.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
